# ========================
# AUTO PULSE — Ortam Değişkenleri
# ========================
# Bu dosyayı .env.local olarak kopyalayıp değerleri doldurun:
# cp .env.example .env.local

# -----------------------------------------------------------------------------
# NEXT.JS CORE
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Auto Pulse"

# -----------------------------------------------------------------------------
# VERCEL ENV (Vercel Dashboard'da ayarlanacak)
# -----------------------------------------------------------------------------
# Production URL (Vercel otomatik doldurur)
NEXT_PUBLIC_VERCEL_URL=
# Vercel Analytics (opsiyonel)
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# -----------------------------------------------------------------------------
# SUPABASE (Faz 9+)
# -----------------------------------------------------------------------------
# Supabase Proje URL'si
NEXT_PUBLIC_SUPABASE_URL=
# Supabase Anon (Public) Key — Client-side işlemler için
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase Service Role Key — Sadece server-side, güvenli işlemler için
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# HUGGING FACE AI (Faz 7+)
# -----------------------------------------------------------------------------
# Hugging Face Access Token — Ücretsiz tier
HUGGINGFACE_API_KEY=
# Kullanılacak model (örn: mistralai/Mistral-7B-Instruct-v0.3)
HUGGINGFACE_MODEL=

# -----------------------------------------------------------------------------
# AI SERVİS ALTERNATİFLERİ
# -----------------------------------------------------------------------------
# Anthropic Claude API (opsiyonel)
ANTHROPIC_API_KEY=
# OpenAI API (opsiyonel)
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# RENDER BACKEND API (Faz 2+)
# -----------------------------------------------------------------------------
# Render'da deploy edilecek backend servis URL'si
RENDER_API_URL=
# Render Internal Servis URL'si (servisler arası iletişim)
RENDER_INTERNAL_API_URL=

# -----------------------------------------------------------------------------
# ANALİTİK (Opsiyonel)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=
