# ========================
# AUTO PULSE - Ortam Degiskenleri
# ========================
# Bu dosyayi .env.local olarak kopyalayip degerleri doldurun:
# cp .env.example .env.local

# -----------------------------------------------------------------------------
# NEXT.JS CORE
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Auto Pulse"

# -----------------------------------------------------------------------------
# VERCEL ENV
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VERCEL_URL=
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# HUGGING FACE AI
# -----------------------------------------------------------------------------
HUGGINGFACE_API_KEY=
HUGGINGFACE_CHAT_MODEL=openai/gpt-oss-120b:fastest
HUGGINGFACE_TEXT_MODEL=google/flan-t5-large
HF_FINEGRAINED_API_KEY=
HF_ZEROSHOT_API_KEY=
HF_SUMMARIZATION_API_KEY=

# -----------------------------------------------------------------------------
# ATOMIC / JAN / OPENAI-COMPATIBLE LOCAL ASSISTANT
# -----------------------------------------------------------------------------
ATOMIC_CHAT_BASE_URL=
ATOMIC_CHAT_MODEL=default

# -----------------------------------------------------------------------------
# PRICE DISPLAY
# -----------------------------------------------------------------------------
# Katalog fiyati gercek piyasa verisi degil, tahmini TL bandi olarak donusturulur.
USD_TRY_RATE=38.5
NEXT_PUBLIC_USD_TRY_RATE=38.5

# -----------------------------------------------------------------------------
# AI SERVIS ALTERNATIFLERI
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# RENDER BACKEND API
# -----------------------------------------------------------------------------
RENDER_API_URL=
RENDER_INTERNAL_API_URL=

# -----------------------------------------------------------------------------
# ANALITIK
# -----------------------------------------------------------------------------
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=
